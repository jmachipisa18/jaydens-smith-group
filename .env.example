# Resend API key from your Resend dashboard.
RESEND_API_KEY="re_your_api_key_here"

# Email address that should receive all customer enquiries.
ENQUIRY_TO_EMAIL="you@example.com"

# Verified sender address used by Resend for outgoing emails.
# For first tests, Resend lets you send to your own account using onboarding@resend.dev.
# For production, replace this with an address on your verified domain.
RESEND_FROM_EMAIL="Jaydens Smith Group <onboarding@resend.dev>"
